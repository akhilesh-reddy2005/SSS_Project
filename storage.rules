rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /receipts/{uid}/{fileName} {
      allow read, write: if isOwner(uid);
    }
  }
}
